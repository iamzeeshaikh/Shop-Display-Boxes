# ── Dependencies and build output ──────────────────────────────────────────
node_modules/
site/node_modules/
site/dist/
site/.astro/
site/.vercel/

# ── Secrets — never commit ─────────────────────────────────────────────────
.env
.env.*
!.env.example
site/.env
site/.env.*
!site/.env.example

# NOTE: site/vercel.json is NOT ignored. Vercel reads it before the build runs,
# so the CSP hashes it contains must be committed. `npm run qa:headers` fails if
# it drifts from the current output.

# ── Generated image derivatives ────────────────────────────────────────────
# src/assets/products/ is produced from Images/ by `npm run images`. Committing
# it would store all 146 photographs a second time (~108 MB) for no benefit.
# Clone, run `npm run images`, then build.
site/src/assets/products/

# ── OS and editor noise ────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
*.log
.vscode/
.idea/
