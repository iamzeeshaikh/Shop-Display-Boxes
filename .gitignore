# ── Dependencies and build output ──────────────────────────────────────────
node_modules/
site/node_modules/
site/dist/
site/.astro/

# ── Secrets — never commit ─────────────────────────────────────────────────
.env
.env.*
!.env.example
site/.env
site/.env.*
