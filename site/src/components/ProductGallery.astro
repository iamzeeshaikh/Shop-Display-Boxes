---
/**
 * Product gallery.
 *
 * The first image is the LCP candidate: it is eager, high priority, and never
 * lazy-loaded. Every other image is lazy with async decoding. All images carry
 * intrinsic width/height so no thumbnail or main frame can shift layout.
 *
 * Thumbnail switching is progressive enhancement — with JavaScript off the
 * thumbnails are anchors to the full images and the main image still renders.
 */
import { Image, Picture } from 'astro:assets';
import type { ImageAlt } from '../data/product-content';

interface Props {
  slug: string;
  imageAlts: ImageAlt[];
  productName: string;
}
const { slug, imageAlts, productName } = Astro.props;

// Eagerly collect this product's images from the assets directory.
// Lazy glob: only the images this product actually renders are imported, so
// unused source PNGs are never emitted into the build output.
const modules = import.meta.glob<{ default: ImageMetadata }>('../assets/products/**/*.png');

const images = await Promise.all(
  imageAlts.map(async (entry) => {
    const key = `../assets/products/${slug}/${entry.file}`;
    const load = modules[key];
    if (!load) {
      throw new Error(
        `ProductGallery: "${entry.file}" is listed in imageAlts for "${slug}" but is not in src/assets/products/${slug}/. Run \`npm run images\`.`
      );
    }
    return { src: (await load()).default, alt: entry.alt };
  })
);

const [primary, ...rest] = images;
---

<div class="gallery">
  <figure class="gallery__main">
    <Picture
      id={`gallery-main-${slug}`}
      src={primary.src}
      alt={primary.alt}
      widths={[480, 720, 960]}
      sizes="(min-width: 64em) 32rem, (min-width: 40em) 50vw, 92vw"
      formats={['avif', 'webp']}
      fallbackFormat="webp"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
      pictureAttributes={{ class: 'gallery__picture' }}
      class="gallery__img"
    />
  </figure>

  {
    rest.length > 0 && (
      <ul class="gallery__thumbs" aria-label={`More views of ${productName}`}>
        {images.map((img, i) => (
          <li>
            <button
              type="button"
              class="gallery__thumb"
              aria-pressed={i === 0 ? 'true' : 'false'}
              aria-label={`Show view ${i + 1} of ${images.length}: ${img.alt}`}
              data-gallery-thumb
              data-index={i}
            >
              {/*
                The thumbnail image is decorative: the button's aria-label
                already carries the description, so alt text here would be
                announced twice.
              */}
              <Image
                src={img.src}
                alt=""
                widths={[72, 144]}
                sizes="72px"
                format="webp"
                loading="lazy"
                decoding="async"
              />
            </button>
          </li>
        ))}
      </ul>
    )
  }
</div>

<script>
  // Thumbnail switching. Swaps the main <img> srcset with the thumbnail's
  // full-size sources, which are already generated by the build.
  document.querySelectorAll<HTMLElement>('.gallery').forEach((gallery) => {
    const main = gallery.querySelector<HTMLImageElement>('.gallery__img');
    const thumbs = gallery.querySelectorAll<HTMLButtonElement>('[data-gallery-thumb]');
    if (!main || !thumbs.length) return;

    // Capture each thumbnail's alt text and the full-size source for its index.
    // Descriptions come from each button's aria-label, since the thumbnail
    // images are decorative and carry no alt text of their own.
    const sources = Array.from(thumbs).map((t) => {
      const label = t.getAttribute('aria-label') || '';
      return { alt: label.replace(/^Show view \d+ of \d+: /, ''), el: t.querySelector('img') };
    });

    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        const img = sources[i].el;
        if (!img) return;
        // The thumbnail and main image share a source set; swapping the
        // srcset/src pair is enough and avoids a second network request.
        main.src = img.src;
        main.srcset = img.srcset;
        main.alt = sources[i].alt || main.alt;
        thumbs.forEach((t, j) => t.setAttribute('aria-pressed', String(i === j)));
      });
    });
  });
</script>

<style>
  .gallery__main {
    margin: 0;
    background: var(--c-paper-warm);
    border: 1px solid var(--c-border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }

  .gallery__img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .gallery__thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    list-style: none;
    margin: var(--s-3) 0 0;
    padding: 0;
  }

  .gallery__thumb {
    display: block;
    width: 72px;
    padding: 0;
    background: var(--c-paper-warm);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    overflow: hidden;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .gallery__thumb img {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .gallery__thumb:hover {
    border-color: var(--c-ink-500);
  }

  .gallery__thumb[aria-pressed='true'] {
    border-color: var(--c-signal-700);
    box-shadow: inset 0 0 0 1px var(--c-signal-700);
  }
</style>
