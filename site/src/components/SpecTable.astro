---
/**
 * Product specification table.
 *
 * Row labels are <th scope="row"> so screen readers announce the field name
 * with each value. The wrapper scrolls horizontally on narrow screens so the
 * page body never overflows.
 */
import type { SpecRow } from '../data/product-content';

interface Props {
  specs: SpecRow[];
  productName: string;
}
const { specs, productName } = Astro.props;
---

<div class="table-wrap">
  <table>
    <caption>{productName} — specification summary</caption>
    <tbody>
      {
        specs.map((row) => (
          <tr>
            <th scope="row">{row.label}</th>
            <td>{row.value}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
<p class="spec-note">
  Values shown as “Custom”, “Depends on order specifications”, or “Available on request” are set
  per job. We confirm them against your artwork and quantity rather than publishing a figure that
  would not hold for every order.
</p>

<style>
  .spec-note {
    margin-block-start: var(--s-3);
    font-size: var(--t-sm);
    color: var(--c-text-subtle);
    max-width: 66ch;
  }
</style>
