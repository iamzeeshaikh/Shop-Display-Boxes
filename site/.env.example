# ─────────────────────────────────────────────────────────────────────────────
# Shop Display Boxes — environment template
#
# Copy to `.env` and fill in. `.env` is gitignored and must never be committed.
# Every value below is a PLACEHOLDER. The site is built so that an empty value
# means "feature off" — no integration loads with a fake or example ID.
# ─────────────────────────────────────────────────────────────────────────────

# ── Form delivery ────────────────────────────────────────────────────────────
# Adapter to use: "resend" | "sendgrid" | "smtp" | "webhook" | "console"
# "console" logs submissions to the server log and is for local development only.
FORM_ADAPTER=console

# Where quote, sample, dieline, and contact submissions are delivered.
FORM_TO_EMAIL=
FORM_FROM_EMAIL=

# Credentials for the selected adapter (fill only the one you use).
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FORM_WEBHOOK_URL=

# Shared secret used to sign CSRF tokens on form submissions.
# Generate with: openssl rand -base64 32
FORM_CSRF_SECRET=

# ── Uploads ──────────────────────────────────────────────────────────────────
# Max artwork upload size in bytes (default 15 MB) and permitted extensions.
UPLOAD_MAX_BYTES=15728640
UPLOAD_ALLOWED_EXT=pdf,ai,eps,psd,svg,png,jpg,jpeg,zip

# ── Analytics (public — these are exposed to the browser by design) ──────────
# Leave blank to load no analytics at all. Never commit a real ID here.
PUBLIC_GA4_MEASUREMENT_ID=
PUBLIC_GTM_CONTAINER_ID=
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_GOOGLE_ADS_CONVERSION_ID=
